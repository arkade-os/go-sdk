# Overrides for the arkade-regtest stack (regtest/ submodule).
# The SDK runs its own arkd via `make regtest`, so only bring up the base
# profile (Bitcoin Core + Fulcrum + nbxplorer + mempool).
REGTEST_PROFILES=base
# Host port 3000 (the SDK's default regtest explorer URL) is served by the
# explorer-shim from test/docker/docker-compose.yml, which proxies to
# mempool_web and fills in esplora's /api/fee-estimates.
MEMPOOL_WEB_PORT=3001
